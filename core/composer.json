{
  "name": "helix/core",
  "description": "Helix Dynamic Form Builder Core Engine - Rule-Based DSL Processor",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "symfony/validator": "^7.2",
    "symfony/serializer": "^7.2",
    "jwadhams/json-logic-php": "^2.0",
    "psr/log": "^3.0",
    "ramsey/uuid": "^4.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Helix\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Helix\\Core\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}